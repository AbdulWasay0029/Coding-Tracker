generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Each Discord user can have multiple platform profiles
model UserProfile {
  id            String   @id @default(uuid())
  discordUserId String   // Discord user snowflake ID
  platform      String   // "LEETCODE", "CODEFORCES", "CODECHEF", "SMARTINTERVIEWS"
  username      String
  token         String?  // Optional — only needed for SmartInterviews
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([discordUserId, platform, username])
}

// Global user settings
model UserSettings {
  discordUserId String   @id
  isPublic      Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}


// Tracks solved problems per user to avoid re-posting duplicates
model SolvedProblem {
  id            String   @id @default(uuid())
  discordUserId String
  platform      String
  problemId     String
  title         String
  solvedAt      DateTime
  createdAt     DateTime @default(now())

  @@unique([discordUserId, platform, problemId])
}

// Per-server configuration (admins only)
model GuildConfig {
  guildId           String   @id
  welcomeChannelId  String?  // Where to post onboarding info
  reminderChannelId String?  // Where to post daily check reminders
  reminderTime      String   @default("22:00") // HH:mm in IST
  contestChannelId  String?  // Where to post contest alerts
  contestRoleId     String?  // Role to ping for contests
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Analytics tracking to understand bot usage
model AnalyticsEvent {
  id            String   @id @default(uuid())
  discordUserId String
  command       String   // e.g., "check", "add-profile", "copy-links", "github-tracker"
  metadata      String?  // Any extra info as JSON string
  createdAt     DateTime @default(now())
}

// Background Job Queue for the scraping engine
model ScrapeJob {
  id            String   @id @default(uuid())
  discordUserId String
  startTimestamp Int
  endTimestamp   Int
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  error         String?
  retries       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// ADDITIVE ONLY: SERVER ROSTER & DEFAULTERS
// ==========================================
model GuildRosterMember {
  id            String   @id @default(uuid())
  guildId       String   // Scoped to the existing Discord Server (GuildConfig)
  rollNumber    String   // e.g., "24R01A0501"
  name          String   // e.g., "Abdul Wasay"
  identifier    String   // The raw CSV value (email or Discord username/ID)
  discordUserId String?  // Optional match to existing UserProfile/SolvedProblem records

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([guildId, rollNumber])
  @@index([guildId])
  @@index([discordUserId])
}
